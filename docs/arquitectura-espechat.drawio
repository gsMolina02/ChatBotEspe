        </mxCell>
        <mxCell id="cliente" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" value="Cliente&#xa;(Navegador web)&#xa;HTML / CSS / JavaScript" vertex="1">
